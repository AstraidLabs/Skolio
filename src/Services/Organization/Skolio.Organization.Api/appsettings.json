{
  "Organization": {
    "Service": {
      "ServiceName": "Skolio.Organization.Api",
      "PublicBaseUrl": "http://localhost:8082"
    },
    "Database": {
      "ConnectionString": "Host=localhost;Port=5432;Database=skolio_organization;Username=skolio;Password=skolio"
    },
    "Redis": {
      "ConnectionString": "localhost:6379",
      "InstanceName": "skolio:organization"
    },
    "Auth": {
      "Authority": "http://localhost:8081",
      "Audience": "skolio_api",
      "RequireHttpsMetadata": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}