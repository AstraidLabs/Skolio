{
  "EmailGateway": {
    "ServiceName": "Skolio.EmailGateway.Api",
    "InternalApiKey": "skolio-internal-email-gateway-key",
    "FromAddress": "noreply@skolio.local",
    "FromDisplayName": "Skolio Security",
    "AllowedTemplateTypes": [
      "PasswordReset",
      "ChangeEmailVerification",
      "SecurityNotification",
      "MfaChanged",
      "AccountConfirmation",
      "AccountInvite"
    ],
    "Smtp": {
      "Host": "localhost",
      "Port": 25,
      "UseSsl": false,
      "RequireAuthentication": false,
      "Username": "",
      "Password": "",
      "ConnectionTimeoutSeconds": 10,
      "CommandTimeoutSeconds": 15
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}