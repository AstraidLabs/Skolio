{
  "Identity": {
    "Service": {
      "ServiceName": "Skolio.Identity.Api",
      "PublicBaseUrl": "http://localhost:8081"
    },
    "Database": {
      "ConnectionString": "Host=localhost;Port=5432;Database=skolio_identity;Username=skolio;Password=skolio"
    },
    "Redis": {
      "ConnectionString": "localhost:6379",
      "InstanceName": "skolio:identity"
    },
    "Identity": {
      "RequiredPasswordLength": 12,
      "RequireNonAlphanumeric": true
    },
    "OpenIddict": {
      "Issuer": "http://localhost:8081",
      "Audiences": [ "skolio-webhost", "skolio-frontend" ]
    },
    "Jwt": {
      "AccessTokenLifetime": "00:30:00",
      "RefreshTokenLifetime": "7.00:00:00"
    },
    "Jwks": {
      "DiscoveryPath": "/.well-known/jwks.json",
      "KeySetId": "skolio-identity-signing-k1"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
